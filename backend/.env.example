# Backend Environment Variables

# Server Configuration
NODE_ENV=development
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:8080

# PostgreSQL connection shared by the three local databases
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=change-me

# Optional split credentials. Source roles should have SELECT-only grants.
# Source sessions are also forced into transaction_read_only mode.
# DASHBOARD_PG_USER=kucsgenai_dashboard_app
# DASHBOARD_PG_PASSWORD=change-me
# SOURCE_PG_USER=kucsgenai_dashboard_reader
# SOURCE_PG_PASSWORD=change-me

# Test target. Do not point this at a production database during development.
DASHBOARD_DB_NAME=kucsgenai_dashboard_test
KUCSGENAI_DB_NAME=kucsgenai
DIFY_DB_NAME=dify

# Demo source generation. Setup/seed scripts only use DEMO_* database names.
# Keep these separate from production and from the default source DB names.
DEMO_DASHBOARD_DB_NAME=kucsgenai_dashboard_demo
DEMO_KUCSGENAI_DB_NAME=kucsgenai_source_demo
DEMO_DIFY_DB_NAME=dify_source_demo
DEMO_SEED=20260708

# Demo simulation knobs. Defaults create a full 2025 dataset with main-DB app
# sampling and time-shifted usage variation. Main DB is read with PG_* unless
# MAIN_* credentials are provided.
# DEMO_START_DATE=2025-01-01
# DEMO_END_DATE=2025-12-31
# DEMO_DAILY_EVENTS=28
# DEMO_USERS_PER_ORG=4
# DEMO_APP_SAMPLE_SIZE=16
# DEMO_USAGE_TEMPLATE_LIMIT=5000
# DEMO_NOTE_COUNT=240
# DEMO_SAMPLE_MAIN_DB=true
# MAIN_KUCSGENAI_DB_NAME=kucsgenai
# MAIN_DIFY_DB_NAME=dify
# MAIN_PG_USER=postgres
# MAIN_PG_PASSWORD=change-me

# Optional admin/seed credentials. These may write to demo source DBs.
# SEED_PG_USER=postgres
# SEED_PG_PASSWORD=change-me

# Optional SELECT-only role for demo sync preflight.
# The sync runtime should use SOURCE_PG_USER/SOURCE_PG_PASSWORD, not SEED_*.
# DEMO_SOURCE_READER_USER=kucsgenai_demo_reader
# DEMO_SOURCE_READER_PASSWORD=change-me

# To run the dashboard against demo data, temporarily point runtime DB names to:
# DASHBOARD_DB_NAME=kucsgenai_dashboard_demo
# KUCSGENAI_DB_NAME=kucsgenai_source_demo
# DIFY_DB_NAME=dify_source_demo

# Apply the reviewed SQL schema on backend startup
RUN_MIGRATIONS=true

# Optional: For production
# DB_POOL_MAX=10

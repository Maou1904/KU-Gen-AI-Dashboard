# Backend Environment Variables

# Server Configuration
NODE_ENV=development
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:8080

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=kucsgenai_dashboard
DB_USER=root
DB_PASSWORD=
DB_DIALECT=mysql
DB_LOG=false
DB_SYNC=true
DB_SYNC_ALTER=false

# Optional: For production
# DB_POOL_MIN=2
# DB_POOL_MAX=10

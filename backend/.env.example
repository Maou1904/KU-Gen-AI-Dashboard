# Backend Environment Variables

# Server Configuration
NODE_ENV=development
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:8080

# PostgreSQL connection shared by the three local databases
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=change-me

# Optional split credentials. Source roles should have SELECT-only grants.
# Source sessions are also forced into transaction_read_only mode.
# DASHBOARD_PG_USER=kucsgenai_dashboard_app
# DASHBOARD_PG_PASSWORD=change-me
# SOURCE_PG_USER=kucsgenai_dashboard_reader
# SOURCE_PG_PASSWORD=change-me

# Test target. Do not point this at a production database during development.
DASHBOARD_DB_NAME=kucsgenai_dashboard_test
KUCSGENAI_DB_NAME=kucsgenai
DIFY_DB_NAME=dify

# Apply the reviewed SQL schema on backend startup
RUN_MIGRATIONS=true

# Optional: For production
# DB_POOL_MAX=10
